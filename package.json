{
  "name": "kostmag",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:safe": "node --max-old-space-size=4096 ./node_modules/next/dist/bin/next dev",
    "build": "next build",
    "start": "next start",
    "deploy": "bash scripts/deploy.sh",
    "lint": "eslint",
    "migrate": "tsx scripts/migrate-from-sql.ts",
    "mem:check": "powershell -ExecutionPolicy Bypass -File scripts/check-memory.ps1",
    "mem:cleanup": "powershell -ExecutionPolicy Bypass -File scripts/check-memory.ps1 -Cleanup -ThresholdMb 4500",
    "mem:json": "powershell -ExecutionPolicy Bypass -File scripts/check-memory.ps1 -Json",
    "mem:watch": "powershell -ExecutionPolicy Bypass -File scripts/check-memory.ps1 -Watch -Cleanup -ThresholdMb 4500 -IntervalSec 5"
  },
  "dependencies": {
    "@mdx-js/loader": "^3.1.1",
    "@mdx-js/react": "^3.1.1",
    "@next/mdx": "^15.5.4",
    "@radix-ui/react-avatar": "^1.1.10",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slot": "^1.2.3",
    "cheerio": "^1.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.2.3",
    "gray-matter": "^4.0.3",
    "lucide-react": "^0.544.0",
    "next": "15.5.4",
    "next-mdx-remote": "^5.0.0",
    "nodemailer": "^7.0.6",
    "openai": "^6.0.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "sharp": "0.32.6",
    "tailwind-merge": "^3.3.1",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@tailwindcss/typography": "^0.5.19",
    "@types/node": "^20",
    "@types/nodemailer": "^7.0.5",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "15.5.4",
    "playwright": "^1.58.2",
    "puppeteer": "^24.38.0",
    "tailwindcss": "^4",
    "tsx": "^4.20.6",
    "typescript": "^5"
  }
}
