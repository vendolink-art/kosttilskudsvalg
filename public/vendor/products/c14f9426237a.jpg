    (function($) {
        var currentUrl = window.location.href;
        var pageType = '';
        var prid = 'productID';

        if ($('.cms-index-index').length) {
            pageType = 'home';
        } else if ($('.catalog-category-view').length) {
            pageType = 'categorie';
        } else if ($('.catalog-product-view').length) {
            pageType = 'product';
            prid = $('#product_addtocart_form .no-display input[name="product"]').val();
        } else if ($('.checkout-cart-index').length) {
            pageType = 'shoppingcart';
        } else {
            pageType = 'pageview';
        }

        var s = document.createElement('script');
        var src = 'https://p.gsitrix.com/page/?a=5d54101e5e62b1565790238&p=' + pageType + '&prid=' + prid + '&av=addservicemedia&as=gp&w=helsegrossisten.dk&ref=' + currentUrl;
        s.type = 'text/javascript';
        s.async = true;
        s.src = src;
        var x = document.getElementsByTagName('script')[0];
        x.parentNode.insertBefore(s, x);
    })(jQuery);
</script>



    <span id="addwish-data" style="display:none"
        data-formkey="/form_key/mkiFOQQ36mnapI7L/"
>
    </span>

<script async src="https://helloretailcdn.com/helloretail.js"></script>
<script>
    (function() {
        /* Addwish 1.0.44 */
        var elm = document.getElementById("addwish-data");
        elm.setAttribute("data-formkey", elm.getAttribute("data-formkey").split("/")[2]);

        window.hrq = window.hrq || [];
        hrq.push(["init", {}]);

        function sendState(state) {
            try {
                if (state.cart) {
                    hrq.push(["setCart", state.cart]);
                }
                if (state.order && state.order.total) {
                    hrq.push(["trackConversion", state.order]);
                }
                if (state.customerEmail) {
                    hrq.push(["setCustomerEmail", state.customerEmail]);
                }
            } catch (e) {
                console.log(e);
            }
        }

        var xhr = new XMLHttpRequest();
        xhr.open("GET", "https://helsegrossisten.dk/awext/index/state?_t=" + new Date().getTime());
        xhr.setRequestHeader("Accept", "application/json");
        xhr.onreadystatechange = function() {
            if (xhr.readyState === 4 && xhr.status == "200") {
                try {
                    var data = JSON.parse(xhr.responseText);
                    sendState(data);
                } catch (e) {
                    console.log("error parsing state", e);
                }
            }
        };
        xhr.send();
    
    })();
