                <script>
        jQuery.ajax({
            url: "/checkout/cart/minicart",
            dataType: 'json',
            type : 'post',
            data: {},
            success: function(data){
                jQuery('#ajax_loader').hide();
                //alert(data.status + ": " + data.message);
                if(jQuery('.minicart')){
                    if(data.qty === null) {
                        jQuery('.minicart .count').text(0);
                    } else {
                        jQuery('.minicart .count').text(data.qty);
                    }
                }
            },
            error: function(error){
                console.log(error);
            }
        });
    </script>

