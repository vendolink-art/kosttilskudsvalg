<style>
.trustpilot-business-rating {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, sans-serif;
    font-size: 14px;
    color: #333;
    width: 100%;
}

.trustpilot-business-rating .rating-text {
    font-size: 12px;
    font-weight: 600;
    color: #FFF;
}

.trustpilot-business-rating .rating-stars {
    display: flex;
    gap: 1px;
}

.trustpilot-business-rating .rating-stars .star {
    font-size: 16px;
    line-height: 1;
}

.trustpilot-business-rating .rating-stars .star.filled {
    color: #00b67a;
}

.trustpilot-business-rating .rating-stars .star.empty {
    color: #ddd;
}

.trustpilot-business-rating .rating-stars .star.partial {
    position: relative;
    color: #ddd;
}

.trustpilot-business-rating .rating-stars .star.partial::before {
    content: '★';
    position: absolute;
    left: 0;
    top: 0;
    color: #00b67a;
    width: var(--fill-percentage);
    overflow: hidden;
    white-space: nowrap;
}

.trustpilot-business-rating .rating-info {
    color: #FFF;
    font-size: 12px;
    white-space: nowrap;
}

.trustpilot-logo-container {
    border-right: 1px solid #FFF;
    padding-right: 8px;
}

.trustpilot-business-rating .trustpilot-logo {
    height: 18px;
    width: auto;
    margin-top: -6px;
    margin-left: 8px;
}

header[role="top"] {
    height: auto!important;
    padding-bottom: 6px;
}

header[role="top"] .left p {
    font-size: 12px;
    margin: 0!important;
}

/* Mobile Trustpilot container styling */
.trustpilot-mobile-container {
    background: #000;
    padding: 8px 0;
    text-align: center;
    border-bottom: 1px solid #333;
}

.trustpilot-mobile-container .trustpilot-business-rating {
    font-size: 12px;
    gap: 6px;
    justify-content: center;
}

.trustpilot-mobile-container .trustpilot-business-rating .rating-stars {
    display: flex;
}

.trustpilot-mobile-container .trustpilot-business-rating .rating-stars .star {
    font-size: 14px;
}

.trustpilot-mobile-container .trustpilot-business-rating .rating-info {
    display: none;
}

/* Responsive adjustments for desktop */
@media (max-width: 768px) {
    .trustpilot-business-rating {
        font-size: 12px;
        gap: 6px;
    }
    
    .trustpilot-business-rating .rating-stars .star {
        font-size: 14px;
    }
    
    .trustpilot-business-rating .rating-info {
        display: none;
    }
}
</style>
